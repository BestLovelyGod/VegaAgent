{
  "manifest_version": 3,
  "name": "Ignorant Vega Browser Bridge",
  "version": "1.0.0",
  "description": "连接 Ignorant Vega Agent 的浏览器自动化桥接扩展",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "cookies",
    "storage",
    "webRequest",
    "nativeMessaging",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Ignorant Vega Browser Bridge",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
