{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1",
  "Urls": "http://localhost:7300",
  "Agent": {
    "Service": {
      "Port": 7300,
      "AutoOpenBrowser": false,
      "TrayMode": true
    },
    "Paths": {
      "DataDir": "data",
      "ToolsDir": "tools",
      "PluginsDir": "plugins",
      "LogsDir": "data/logs",
      "SecurityDir": "data/security",
      "SdkDir": "sdk",
      "EditorDir": "editor"
    },
    "Llm": {
      "Endpoint": "https://token-plan-cn.xiaomimimo.com/v1",
      "DefaultModel": "mimo-v2.5",
      "Models": {
        "Coding": "mimo-v2.5",
        "Planning": "mimo-v2.5",
        "Chat": "mimo-v2.5"
      },
      "MaxTokens": 32768,
      "Temperature": 0.7,
      "MaxLoopIterations": 200,
      "MaxLoopMessages": 500,
      "MaxLoopTotalTokens": 2147483647,
      "MaxLoopTimeoutMinutes": 0,
      "TimeoutSeconds": 120
    },
    "Security": {
      "DefaultReviewMode": "Auto",
      "WhitelistEnabled": true,
      "WhitelistPath": "data/security/whitelist.json"
    },
    "Logging": {
      "MinimumLevel": "Information",
      "FileEnabled": true,
      "FileMaxSizeMB": 50,
      "RetainDays": 30
    }
  }
}
